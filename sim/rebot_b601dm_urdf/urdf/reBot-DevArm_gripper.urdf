      <geometry>
        <box size="0.065 0.0315 0.0394" />
      </geometry>
    </collision>
  </link>

  <!-- RIGHT finger (-Y side). 01_Finger, tool-frame mesh.
       AABB (tool, m): X[-0.1603,-0.0953] Y[-0.0314,0.0001] Z[+-0.0197]. -->
  <link
