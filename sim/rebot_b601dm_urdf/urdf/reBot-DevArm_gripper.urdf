  <!-- Left finger prismatic joint: opens along tool +Y.
       Origin = tool origin (mesh carries its own tool position). lower=0 = CAD
       closed pose, upper=0.0425 = full open (half of 0.085 m jaw span).
       effort 91 (SDK), velocity 0.1 m/s APPROX. Coupled to right_finger_joint
       Isaac-side (two independent prismatic joints, no <mimic>, for robust PhysX). -->
  <joint
    name="left_finger_joint"
    type="prismatic">
    <origin
      xyz="0 0 0"
      rpy="0 0 0" />
    <parent
      link="end_link" />
    <child
      link="left_finger" />
    <axis
      xyz="0 1 0" />
    <limit
      lower="0"
      upper="0.0425"
      effort="91"
      velocity="0.1" />
    <dynamics
      damping="5.0"
      friction="1.0" />
  </joint>

  <!-- Right finger prismatic joint: mirror, opens along tool -Y. -->
  <joint
    name="right_finger_joint"
    type="prismatic">
    <origin
      xyz="0 0 0"
      rpy="0 0 0" />
    <parent
      link="end_link" />
    <child
      link="right_finger" />
    <axis
      xyz="0 -1 0" />
    <limit
      lower="0"
      upper="0.0425"
      effort="91"
      velocity="0.1" />
    <dynamics
      damping="5.0"
      friction="1.0" />
  </joint>

