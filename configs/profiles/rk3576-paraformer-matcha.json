{
  "name": "rk3576-paraformer-matcha",
  "description": "Rockchip RK3576 Paraformer + Matcha: current validated Paraformer RKNN ASR path (hybrid NPU encoder + RKNN decoder) with Matcha RKNN TTS. This legacy profile name is kept as the default Paraformer selection alias.",
  "asr_backend": "rk.asr",
  "tts_backend": "rk.tts",
  "execution_policy": {
    "mode": "serialized",
    "shared_resource": "npu"
  },
  "env": {
    "LANGUAGE_MODE": "rk",
    "RK_PLATFORM": "rk3576",
    "RK_ARTIFACT_SET": "rk3576-paraformer-hybrid-rknn-decoder-2026-06-09",
    "ASR_BACKEND": "paraformer_rknn",
    "PARAFORMER_MODEL_DIR": "/opt/asr/paraformer",
    "PARAFORMER_RKNN_DIR": "/opt/asr/paraformer/rknn/rk3576",
    "PARAFORMER_RKNN_ENC_PRECISION": "fp16",
    "PARAFORMER_RKNN_DEC_PRECISION": "fp16",
    "PARAFORMER_RKNN_ENCODER_MODE": "hybrid",
    "PARAFORMER_RKNN_DECODER": "rknn",
    "PARAFORMER_FBANK_CMVN": "none",
    "PARAFORMER_STREAM_DECODE": "batch_final",
    "PARAFORMER_STREAM_PROCESS_SEC": "2.0",
    "PARAFORMER_ENCODER_SUFFIX_ONNX": "/opt/asr/paraformer/encoder_suffix_from_block30.onnx",
    "PARAFORMER_RKNN_ENC_CORE": "NPU_CORE_1",
    "PARAFORMER_RKNN_DEC_CORE": "NPU_CORE_0",
    "PARAFORMER_PREROLL_MS": "100",
    "TTS_MODEL_DIR": "/opt/tts/models",
    "TTS_BACKEND": "matcha_rknn",
    "SHERPA_TTS_MODEL_DIR": "/opt/tts/models/matcha-icefall-zh-en",
    "TTS_PROVIDER": "cpu",
    "TTS_NUM_THREADS": "4",
    "TTS_DEFAULT_SID": "0",
    "MODEL_DIR": "/opt/tts/models",
    "MATCHA_USE_ORT": "1",
    "MATCHA_MODEL": "matcha-s64.rknn",
    "MATCHA_MAX_PHONEMES": "64",
    "MATCHA_MODEL_SEQ_LEN": "80",
    "VOCOS_MODEL": "vocos-16khz-600.rknn",
    "VOCOS_FRAMES": "600"
  },
  "tts_model_id": "matcha-icefall-zh-en.rknn"
}
