{
  "name": "jetson-edgellm-v090-n2",
  "description": "v0.9.0 edgellm N=2 (two concurrent sessions) — CustomVoice TTS + streaming ASR, both at concurrency 2. DERIVED from jetson-edgellm-v090-customvoice (which is N=1 by design) with the SESSION-GATE TRIPLE flipped (mirrors v080 jetson-edgellm-v080-n2): LAZY_TTS=1 (lazy-load the TTS worker so both slots warm independently), OVS_TTS_WORKER_CONCURRENCY=2 (2nd TTS slot-pool lane), OVS_MAX_CONCURRENT_SESSIONS=2 (admit 2 sessions; 3rd -> 4429 too_many_sessions). ASR N=2 REQUIRES the batch-2 thinker engine (asr-b2): maxSessionBatchSize() reads the engine max batch (=2) so SessionLaneManager opens 2 lanes — the N=1 batch-1 engine caps at 1 lane. So this profile OVERRIDES EDGE_LLM_ASR_ENGINE_DIR to the baked asr_thinker_full_int4_b2 (v090 asr-b2, --maxBatchSize 2 --maxKVCacheCapacity 1536, md5 75f20e77; the audio encoder is time-step based / batch-agnostic and is SHARED with N=1). TTS uses the shared-engine ctor (EDGE_LLM_TTS_SHARED_ENGINE=1) so the 2nd TTS slot reuses the resident talker/cp weights (+~1.6 GB instead of a full 2nd copy) — fits 16 GB Orin NX. Verified on orin-nx: ASR two-lane (CER 0, no cross-talk, 3rd->4429, concurrent==solo byte-identical, 0 CUDA, ~1971 MB); TTS N=2 shared-engine byte-identical (P2-M3/P3b-2). Everything else inherited from -customvoice. Base image: the v090 prefix (bakes asr_thinker_full_int4_b2 alongside the N=1 engines).",
  "asr_backend": "jetson.trt_edge_llm",
  "tts_backend": "jetson.trt_edge_llm",
  "tts_model_id": "qwen3-tts-customvoice",
  "execution_policy": {
    "mode": "concurrent",
    "shared_resource": "gpu"
  },
  "artifact_set": "edgellm-v090",
  "env": {
    "LANGUAGE_MODE": "multilanguage",
    "ASR_BACKEND": "trt_edgellm",
    "TTS_BACKEND": "trt_edgellm",
    "OVS_VAD_BACKEND": "silero",
    "OVS_VAD_SILENCE_MS": "400",
    "EDGE_LLM_QWEN3_PROFILE": "highperf",
    "EDGE_LLM_ASR_WORKER": "1",
    "EDGE_LLM_ASR_VOCAB_PRUNED": "0",
    "QWEN3_EDGELLM_JETSON_ROOT": "/opt/qwen3-edgellm-jetson",
    "EDGE_LLM_ASR_STREAM_MODE": "worker",
    "EDGELLM_REQUEST_AUDIO_WAV": "1",
    "EDGE_LLM_ASR_STREAM_CHUNK_SEC": "0.5",
    "EDGE_LLM_ASR_STREAM_UNFIXED_CHUNKS": "2",
    "EDGE_LLM_ASR_STREAM_UNFIXED_TOKENS": "5",
    "EDGE_LLM_ASR_MAX_CONCURRENT": "2",
    "EDGE_LLM_ASR_ENGINE_DIR": "/opt/edgellm-v090/engines/asr_thinker_full_int4_b2",
    "EDGE_LLM_ASR_AUDIO_ENC_DIR": "/opt/edgellm-v090/engines/asr_audio_encoder",

    "EDGE_LLM_TTS_WORKER": "1",
    "EDGE_LLM_TTS_WORKER_BIN": "/opt/edgellm-v090/bin/qwen3_tts_streaming_worker",
    "EDGELLM_PLUGIN_PATH": "/opt/edgellm-v090/libNvInfer_edgellm_plugin.so",
    "EDGE_LLM_TTS_TALKER_DIR": "/opt/edgellm-v090/engines/tts_talker_int4_b2",
    "EDGE_LLM_TTS_CP_DIR": "/opt/edgellm-v090/engines/tts_code_predictor",
    "EDGE_LLM_TTS_CODE2WAV_DIR": "/opt/edgellm-v090/engines/tts_code2wav_lean",
    "EDGE_LLM_TTS_TOKENIZER_DIR": "/opt/models/qwen3-tts-customvoice/tokenizer",
    "EDGE_LLM_TTS_STATEFUL_CODE2WAV": "0",
    "EDGE_LLM_TTS_STREAMING_ONLY": "1",
    "EDGE_LLM_TTS_SHARED_ENGINE": "1",
    "EDGE_LLM_TTS_CHUNK_FRAMES": "13",
    "TTS_MAX_AUDIO_LENGTH": "1024",
    "OVS_TTS_MODEL_ID": "qwen3-tts-customvoice",
    "LAZY_TTS": "1",
    "OVS_TTS_WORKER_CONCURRENCY": "2",
    "OVS_MAX_CONCURRENT_SESSIONS": "2",
    "OVS_TTS_SAMPLE_RATE": "24000",
    "OVS_TTS_CHANNELS": "1",
    "OVS_TTS_SEED": "42"
  },
  "tts_worker_concurrency": 2,
  "profile_owned_env": [
    "EDGELLM_REQUEST_AUDIO_WAV",
    "EDGE_LLM_ASR_MAX_CONCURRENT",
    "EDGE_LLM_ASR_ENGINE_DIR",
    "EDGE_LLM_ASR_AUDIO_ENC_DIR",
    "EDGE_LLM_TTS_WORKER",
    "EDGE_LLM_TTS_WORKER_BIN",
    "EDGELLM_PLUGIN_PATH",
    "EDGE_LLM_TTS_TALKER_DIR",
    "EDGE_LLM_TTS_CP_DIR",
    "EDGE_LLM_TTS_CODE2WAV_DIR",
    "EDGE_LLM_TTS_TOKENIZER_DIR",
    "EDGE_LLM_TTS_STATEFUL_CODE2WAV",
    "EDGE_LLM_TTS_STREAMING_ONLY",
    "EDGE_LLM_TTS_SHARED_ENGINE",
    "EDGE_LLM_TTS_CHUNK_FRAMES",
    "OVS_TTS_MODEL_ID",
    "LAZY_TTS",
    "OVS_TTS_WORKER_CONCURRENCY",
    "OVS_MAX_CONCURRENT_SESSIONS"
  ],
  "required_engines": [
