{
  "name": "jetson-qwen3-composition-nx",
  "description": "Composition-mode Qwen3 ASR + Qwen3 TTS N1 profile for Orin NX (profiling device). The leaf registry (configs/leaves/) supplies the EDGE_LLM_* engine path + backend-mode env and the union-pull artifact file list; this profile carries only the operator-owned boot env (language mode, backends, worker config, artifact set/root, TTS tuning). It deliberately OMITS required_engines: the leaf env sets the Qwen3 engine paths and the engine_resolver only acts on profile.required_engines, so the resolver runs as a no-op here.",
  "asr_backend": "jetson.trt_edge_llm",
  "tts_backend": "jetson.trt_edge_llm",
  "execution_policy": {
    "mode": "concurrent",
    "shared_resource": "trt"
  },
  "artifact_set": "orin-nx-highperf-2026-05-14",
  "env": {
    "LANGUAGE_MODE": "multilanguage",
    "ASR_BACKEND": "trt_edgellm",
    "TTS_BACKEND": "trt_edgellm",
    "OVS_VAD_BACKEND": "silero",
    "OVS_VAD_SILENCE_MS": "400",
    "EDGE_LLM_QWEN3_PROFILE": "highperf",
    "EDGE_LLM_ASR_WORKER": "1",
    "EDGE_LLM_ASR_WORKER_BIN": "/opt/jv-workers/qwen3_asr_worker",
    "EDGE_LLM_TTS_WORKER": "1",
    "EDGE_LLM_TTS_WORKER_BIN": "/opt/jv-workers/qwen3_tts_worker",
    "OVS_TTS_WORKER_CONCURRENCY": "1",
    "EDGELLM_PLUGIN_PATH": "/opt/edgellm-bin/libNvInfer_edgellm_plugin.so",
    "EDGE_LLM_ASR_PLUGIN_PATH": "/opt/edgellm-bin/libNvInfer_edgellm_plugin_asr.so",
    "EDGE_LLM_TTS_BACKEND": "edgellm_worker",
    "EDGE_LLM_ASR_VOCAB_PRUNED": "0",
    "EDGE_LLM_TTS_VOCAB_PRUNED": "0",
    "EDGE_LLM_TTS_LAZY_CODE2WAV": "0",
    "EDGE_LLM_TTS_CJK_SEGMENT_MAX_CHARS": "48",
    "OVS_TTS_LOW_LATENCY_CJK_MIN_CHARS": "24",
    "OVS_TTS_LOW_LATENCY_CJK_TARGET_CHARS": "32",
    "OVS_TTS_LOW_LATENCY_CJK_MAX_CHARS": "48",
    "EDGE_LLM_TTS_SEGMENT_PAUSE_MS": "20",
    "EDGE_LLM_TTS_HARD_SEGMENT_PAUSE_MS": "60",
    "EDGE_LLM_TTS_CODE2WAV_CONTEXT_FRAMES": "0",
    "EDGE_LLM_TTS_FIRST_CHUNK_FRAMES": "7",
    "EDGE_LLM_TTS_CHUNK_FRAMES": "10",
    "EDGE_LLM_TTS_MAX_CHUNK_FRAMES": "10",
    "OVS_TTS_SEED": "42",
    "OVS_TTS_TALKER_TEMPERATURE": "0.0",
    "OVS_TTS_TALKER_TOP_K": "1",
    "OVS_TTS_PREDICTOR_TEMPERATURE": "0.0",
    "OVS_TTS_PREDICTOR_TOP_K": "1",
    "OVS_TTS_SPEAKERS_JSON": "{\"0\":\"\",\"2301\":\"2301\",\"2302\":\"2302\"}",
    "OVS_TTS_ALLOW_UNMAPPED_SPEAKER_ID": "1",
    "QWEN3_TTS_CP_DECODE_CUDA_GRAPH": "1",
    "QWEN3_TTS_ACTIVE_CP_GROUPS": "13",
    "EDGE_LLM_TTS_PERF_PROFILE": "balanced",
    "QWEN3_ARTIFACT_MANIFEST": "deploy/artifacts/qwen3_manifest.json",
    "QWEN3_ARTIFACT_SET": "orin-nx-highperf-2026-05-14",
    "QWEN3_ARTIFACT_ROOT": "/opt/models/qwen3-edgellm",
    "QWEN3_EDGELLM_JETSON_ROOT": "/opt/qwen3-edgellm-jetson",
    "EDGE_LLM_ASR_STREAM_MODE": "worker",
    "EDGE_LLM_ASR_STREAM_CHUNK_SEC": "0.5",
    "EDGE_LLM_ASR_STREAM_UNFIXED_CHUNKS": "2",
    "EDGE_LLM_ASR_STREAM_UNFIXED_TOKENS": "5",
    "EDGE_LLM_ASR_MEL_SETTINGS": "${QWEN3_EDGELLM_JETSON_ROOT}/deploy/audio_preprocessing/whisper_feature_extractor.json",
    "EDGE_LLM_ASR_MEL_FILTERS": "${QWEN3_EDGELLM_JETSON_ROOT}/deploy/audio_preprocessing/mel_filters.bin"
  },
  "tts_model_id": "qwen3-tts-customvoice",
  "composition": {
    "device": "orin-nx",
    "asr": "asr.qwen3_asr.orin-nx.n2",
    "tts": "tts.qwen3_tts.orin-nx.n1"
  }
}
