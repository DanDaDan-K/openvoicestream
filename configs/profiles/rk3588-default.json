{
  "name": "rk3588-default",
  "description": "Rockchip RK3588 release profile: Qwen3 ASR on RKNN/RKLLM W8A8 plus Matcha hybrid TTS (ORT acoustic + RKNN Vocos) validated by TTS-to-ASR closed-loop. W8A8 is the default RK3588 decoder after the 2026-06-09 highperf short-set recheck.",
  "asr_backend": "rk.asr",
  "tts_backend": "rk.tts",
  "execution_policy": {
    "mode": "serialized",
    "shared_resource": "npu"
  },
  "env": {
    "LANGUAGE_MODE": "rk",
    "RK_PLATFORM": "rk3588",
    "RK_ARTIFACT_SET": "rk3588-multilang-2026-05-17",
    "ASR_BACKEND": "qwen3_asr_rk",
    "OVS_VAD_BACKEND": "silero",
    "OVS_VAD_SILENCE_MS": "400",
    "ASR_DECODER_TYPE": "rkllm",
    "ASR_PLATFORM": "rk3588",
    "ASR_DECODER_QUANT": "w8a8",
    "ASR_DECODER_EMBED_CACHE_REUSE": "1",
    "ASR_DECODER_ASYNC": "1",
    "ASR_MAX_NEW_TOKENS": "64",
    "ASR_FINAL_STOP_ON_PUNCT": "1",
    "ASR_FINAL_STOP_MIN_CHARS": "8",
    "ASR_FINAL_STOP_MIN_CHUNKS": "2",
    "ASR_NPU_CORE_MASK": "NPU_CORE_AUTO",
    "ASR_ENABLED_CPUS": "4",
    "ASR_MODEL_DIR": "/opt/asr/models",
    "RKLLM_LIB_PATH": "/opt/asr/lib/librkllmrt.so",
    "QWEN3_ASR_CHUNK_CONFIRM": "0",
    "QWEN3_ASR_STREAM_MODE": "true_streaming",
    "QWEN3_ASR_STREAM_TRUE": "1",
    "QWEN3_ASR_TRUE_ROLL_SEC": "5",
    "QWEN3_ASR_TRUE_PARTIAL_TOKENS": "8",
    "QWEN3_ASR_TRUE_PARTIAL_INTERVAL_MS": "1500",
    "QWEN3_ASR_TRUE_PARTIAL_WARMUP": "2",
    "QWEN3_ASR_VAD_FINAL_ASYNC": "1",
    "QWEN3_ASR_FRONTEND_EOU_MIN_AUDIO_S": "2.5",
    "TTS_MODEL_DIR": "/opt/tts/models",
    "TTS_BACKEND": "matcha_rknn",
    "SHERPA_TTS_MODEL_DIR": "/opt/tts/models/matcha-icefall-zh-en",
    "TTS_PROVIDER": "cpu",
    "TTS_NUM_THREADS": "4",
    "TTS_DEFAULT_SID": "0",
    "MODEL_DIR": "/opt/tts/models",
    "MATCHA_USE_ORT": "1",
    "MATCHA_MODEL": "matcha-s64.rknn",
    "MATCHA_MAX_PHONEMES": "64",
    "MATCHA_MODEL_SEQ_LEN": "80",
    "VOCOS_MODEL": "vocos-16khz-600.rknn",
    "VOCOS_FRAMES": "256"
  },
  "tts_model_id": "matcha-icefall-zh-en.rknn"
}
