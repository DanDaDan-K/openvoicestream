{
  "name": "rk3588-sensevoice",
  "description": "Rockchip RK3576: SenseVoice offline ASR on the NPU (RKNN fp16, zh/en/ja/ko/yue) via ASR_BACKEND=sensevoice_rknn, plus Matcha hybrid TTS. SenseVoice serves the offline /asr path (encoder+CTC, validated on real RK3576 NPU).",
  "asr_backend": "rk.asr",
  "tts_backend": "rk.tts",
  "execution_policy": {
    "mode": "serialized",
    "shared_resource": "npu"
  },
  "env": {
    "LANGUAGE_MODE": "rk",
    "RK_PLATFORM": "rk3588",
    "ASR_BACKEND": "sensevoice_rknn",
    "ASR_PLATFORM": "rk3588",
    "SENSEVOICE_RKNN_MODEL_DIR": "/opt/asr/sensevoice-rknn",
    "ASR_NPU_CORE_MASK": "NPU_CORE_0",
    "ASR_MODEL_DIR": "/opt/asr/models",
    "OVS_VAD_BACKEND": "silero",
    "OVS_VAD_SILENCE_MS": "400",
    "TTS_MODEL_DIR": "/opt/tts/models",
    "TTS_BACKEND": "matcha_rknn",
    "SHERPA_TTS_MODEL_DIR": "/opt/tts/models/matcha-icefall-zh-en",
    "TTS_PROVIDER": "cpu",
    "TTS_NUM_THREADS": "4",
    "TTS_DEFAULT_SID": "0",
    "MODEL_DIR": "/opt/tts/models",
    "MATCHA_USE_ORT": "1",
    "MATCHA_MODEL": "matcha-s64.rknn",
    "MATCHA_MAX_PHONEMES": "64",
    "MATCHA_MODEL_SEQ_LEN": "80",
    "VOCOS_MODEL": "vocos-16khz-600.rknn",
    "VOCOS_FRAMES": "600"
  },
  "tts_model_id": "matcha-icefall-zh-en.rknn"
}
