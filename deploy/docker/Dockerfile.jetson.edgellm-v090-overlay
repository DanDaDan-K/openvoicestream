# edgellm v0.9.0 SLV overlay for Jetson Orin NX — thin overlay on a v090
# prefix base image (pattern: Dockerfile.jetson.edgellm-moss-nx).
#
# The BASE image (built at P5 from fork pin integration/v090-sparktts@e8c59c1,
# seeed submodule pin repin/v090-overlay@95e97e9) must already contain the
# baked v090 runtime layout:
#   /opt/edgellm-v090/libNvInfer_edgellm_plugin.so   (single plugin: ASR+TTS)
#   /opt/edgellm-v090/bin/{qwen3_asr_worker,qwen3_tts_streaming_worker}
#   /opt/edgellm-v090/engines/{asr_thinker_full_int4,asr_audio_encoder,
#       tts_talker_int4_b2,tts_code_predictor,tts_code2wav_lean,
#       tts_base_talker,tts_base_code_predictor,tts_base_code2wav_lean,
#       tts_base_spk_encoder}          (md5 map: configs/leaves/*-v090.yaml)
# plus ENV EDGELLM_PLUGIN_PATH=/opt/edgellm-v090/libNvInfer_edgellm_plugin.so
# (v0.9.0 resolves the plugin relative to CWD when the env is unset/relative).
#
# This overlay only stages the v090 profiles so OVS_PROFILE can select them.
# Build context: this directory with the three profile JSONs copied in flat
# (same convention as the moss-nx overlay).
#
# TODO(P5): pin BASE to the published v090 prefix tag before building.
ARG BASE=sensecraft-missionpack.seeed.cn/solution/seeed-local-voice:TODO-v090-prefix-tag-set-at-P5
FROM ${BASE}

# Belt-and-braces: re-assert the v090 plugin path even if the base pre-dates
# the env bake (operator env still wins over profile env at runtime).
ENV EDGELLM_PLUGIN_PATH=/opt/edgellm-v090/libNvInfer_edgellm_plugin.so

COPY jetson-edgellm-v090-qwen3ttsbase.json /opt/speech/configs/profiles/jetson-edgellm-v090-qwen3ttsbase.json
COPY jetson-edgellm-v090-moss.json /opt/speech/configs/profiles/jetson-edgellm-v090-moss.json
COPY jetson-edgellm-v090-customvoice.json /opt/speech/configs/profiles/jetson-edgellm-v090-customvoice.json
