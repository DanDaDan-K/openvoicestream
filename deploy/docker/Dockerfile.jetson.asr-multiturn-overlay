# Thin overlay: patch /asr/stream into a proper multi-utterance ASR endpoint
# (server-VAD endpoint no longer closes the socket per utterance) on top of a
# server/-layout base image. Builds in seconds — only rewrites one .py file.
#
# Base MUST be a server/-layout image (has /opt/speech/server/main.py), e.g.
# seeed-local-voice:server-loop-prod-v6-asrlock. The patch script fails the
# build if the anchor isn't found (base diverged).
#
# Build (context = repo root, on the arm64 device; --sudo docker):
#   docker build -f deploy/docker/Dockerfile.jetson.asr-multiturn-overlay \
#     --build-arg BASE=sensecraft-missionpack.seeed.cn/solution/seeed-local-voice:server-loop-prod-v6-asrlock \
#     -t sensecraft-missionpack.seeed.cn/solution/seeed-local-voice:server-loop-prod-v7-asrmultiturn .
#
# Run with the SAME env/mounts/ports as the existing seeed-voice container, but
# let the image's DEFAULT cmd run (server.main:app — do NOT override with the
# old app.main:app).
ARG BASE=sensecraft-missionpack.seeed.cn/solution/seeed-local-voice:server-loop-prod-v6-asrlock
FROM ${BASE}

COPY deploy/docker/_patch_asr_multiturn.py /tmp/_patch_asr_multiturn.py
RUN python3 /tmp/_patch_asr_multiturn.py && rm -f /tmp/_patch_asr_multiturn.py

LABEL build.overlay="asr-multiturn"
LABEL build.base="${BASE}"
