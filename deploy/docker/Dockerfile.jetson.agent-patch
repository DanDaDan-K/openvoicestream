# Thin "diff" Dockerfile for the voice-arm AGENT — overlays ONLY changed
# ovs_agent Python files onto a previous production agent image. The
# production agent image carries openwakeword deps + /app/entrypoint.sh
# (mic/arm hardware bring-up) + the /opt/openvoicestream layout that the
# standalone agent/Dockerfile lacks, so a wake-skip-only change MUST be
# layered on the real production base, not rebuilt from agent/Dockerfile.
#
# Build (BASE = current running voice-arm image; OVS_DIR = where ovs_agent
# is IMPORTED from in that image — NOT necessarily PYTHONPATH. On the prod
# image PYTHONPATH=/opt/openvoicestream has no ovs_agent; the imported copy
# lives in site-packages. ALWAYS verify:
#   docker run --rm --entrypoint python3 <BASE> -c "import ovs_agent; print(ovs_agent.__path__)"
# ):
#   docker build -f deploy/docker/Dockerfile.jetson.agent-patch \
#       --build-arg BASE=<current-image:tag> \
#       --build-arg OVS_DIR=/usr/local/lib/python3.11/site-packages \
#       -t <current-image>:<new-tag> .
#
# Build context root must contain the listed agent/ovs_agent/*.py files.
# COPY only the specific changed files — NOT the whole tree — to avoid
# dragging in unrelated uncommitted WIP that may sit in the working copy.

ARG BASE
FROM ${BASE}

# CRITICAL — the prod entrypoint exports
#   PYTHONPATH="/app:/opt/openvoicestream/agent:${PYTHONPATH}"
# and a copy of the package lives at BOTH /opt/openvoicestream/agent/ovs_agent
# AND /usr/local/lib/python3.11/site-packages/ovs_agent. PYTHONPATH wins, so
# the daemon imports the /opt/openvoicestream/agent copy — patching only
# site-packages (what `docker run --entrypoint python3 -c import` resolves to,
# because that invocation lacks the daemon's PYTHONPATH) is a silent no-op that
# verifies green via getsource yet never executes. Overlay BOTH locations so
# whichever path wins, the daemon runs the new code. Primary = the daemon path.
ARG OVS_DIR=/opt/openvoicestream/agent
ARG OVS_DIR_ALT=/usr/local/lib/python3.11/site-packages
COPY agent/ovs_agent/config.py              ${OVS_DIR}/ovs_agent/config.py
COPY agent/ovs_agent/app_base.py            ${OVS_DIR}/ovs_agent/app_base.py
COPY agent/ovs_agent/slv_client.py          ${OVS_DIR}/ovs_agent/slv_client.py
COPY agent/ovs_agent/apps/multi_mode/app.py ${OVS_DIR}/ovs_agent/apps/multi_mode/app.py
COPY agent/ovs_agent/config.py              ${OVS_DIR_ALT}/ovs_agent/config.py
COPY agent/ovs_agent/app_base.py            ${OVS_DIR_ALT}/ovs_agent/app_base.py
COPY agent/ovs_agent/slv_client.py          ${OVS_DIR_ALT}/ovs_agent/slv_client.py
COPY agent/ovs_agent/apps/multi_mode/app.py ${OVS_DIR_ALT}/ovs_agent/apps/multi_mode/app.py

LABEL build.diff-type="ovs_agent-wakeskip+wakephrase+callid"
LABEL build.diff-base="${BASE}"
