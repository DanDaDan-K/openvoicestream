# syntax=docker/dockerfile:1.6
#
# OpenVoiceStream — Jetson Orin Nano / NX / AGX (JetPack 6.x, CUDA 12.6, TRT 10.3)
#
# Single Python dependency set, selected at runtime by profile:
#   jetson-zh-en                 — Paraformer ASR + Matcha TTS (zh_en default)
#   jetson-qwen3asr-matcha-nx    — Qwen3 ASR + Matcha TTS (multilanguage default,
#                                  runs on Nano 8GB and NX 16GB)
#   jetson-multilang-highperf    — Qwen3 ASR + Qwen3 TTS heavy preset (NX/AGX only)
#
# ── Multi-target (BAKE_MODELS) ──────────────────────────────────────────────
# This Dockerfile defines THREE stages:
#   base         — code + runtime libs + worker binaries + required .so
#                  (shared by both variants; NO model/engine artifacts).
#   final-thick  — FROM base + COPY baked model/engine artifacts (factory /
#                  offline image; CustomVoice ref talker embeds baked in).
#   final-slim   — FROM base only; model/engine artifacts are pulled at first
#                  start from HF/CDN by app/core/model_downloader.py.
# Docker cannot conditionally skip a COPY, so the two variants are separate
# BuildKit targets selected via --target.
#
# Build THICK (factory / offline, ~ baked):
#   docker build -f deploy/docker/Dockerfile.jetson --target final-thick \
#                --build-arg LANGUAGE_MODE=zh_en \
#                -t openvoicestream:jetson-zh_en-thick .
#
# Build SLIM (runtime-pull, ~500MB-1GB):
#   docker build -f deploy/docker/Dockerfile.jetson --target final-slim \
#                --build-arg LANGUAGE_MODE=zh_en \
#                -t openvoicestream:jetson-zh_en-slim .
#
# Default `docker build` (no --target) builds the LAST stage (final-slim).
#
# Runtime (GPU access requires --runtime=nvidia):
#   docker run --runtime=nvidia --network=host \
#     -e OVS_PROFILE=jetson-zh-en \
#     -v seeed-models:/opt/models \
#     openvoicestream:jetson-zh_en-slim

ARG LANGUAGE_MODE=zh_en

# ===========================================================================
# Stage: base — code + runtime libs + worker binaries + .so (both variants)
# ===========================================================================
FROM arm64v8/ubuntu:22.04 AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# Build-time PyPI mirror
ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_INDEX_URL=${PIP_INDEX}

# System deps + Python 3.10
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.10 python3.10-dev python3-pip \
        libasound2 libsndfile1 sox curl ca-certificates binutils bzip2 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1 \
    && rm -rf /var/lib/apt/lists/*

# FastAPI + runtime deps (shared by both modes)
RUN pip3 install --no-cache-dir --index-url ${PIP_INDEX} \
        fastapi \
        "uvicorn[standard]" \
        soundfile \
        python-multipart \
        numpy \
        tokenizers \
        "webrtcvad-wheels>=2.0.14" \
        "cuda-python>=12,<13" \
        websockets \
        requests \
        "pysbd>=0.3.4" \
        "onnxruntime>=1.20" \
        prometheus_client \
        httpx \
        piper-phonemize

ARG LANGUAGE_MODE=zh_en
ENV LANGUAGE_MODE=${LANGUAGE_MODE}

RUN set -eux; \
    case "$LANGUAGE_MODE" in \
      zh_en) echo "OVS_PROFILE_DEFAULT=jetson-zh-en" >> /etc/openvoicestream.env ;; \
      multilanguage) echo "OVS_PROFILE_DEFAULT=jetson-qwen3asr-matcha-nx" >> /etc/openvoicestream.env ;; \
      *) echo "Unknown LANGUAGE_MODE=$LANGUAGE_MODE (expected zh_en|multilanguage)" >&2; exit 1 ;; \
    esac; \
    rm -rf /root/.cache /tmp/*

# Application code
COPY app/      /opt/speech/app/
COPY configs/  /opt/speech/configs/
COPY voices/   /opt/speech/voices/
COPY deploy/artifacts/ /opt/speech/deploy/artifacts/
COPY deploy/docker/entrypoint.jetson.sh /opt/speech/entrypoint.jetson.sh
RUN chmod +x /opt/speech/entrypoint.jetson.sh

# ── voxedge (edge-native voice library) ───────────────────────────────
# Post-migration app/ imports voxedge.* (main.py, voxedge_backend_config.py);
# install the pure-Python py3-none-any wheel (numpy-only core) WITHOUT extras —
# heavy backend deps (tensorrt / cuda-python / onnxruntime) are already in this
# image and voxedge's backend imports are lazy. The wheel is staged into
# deploy/wheels/ on the build host (sibling repo, outside the build context).
# See docs/specs/cutover-dockerfile-draft.md §2.
COPY deploy/wheels/voxedge-0.0.1a0-py3-none-any.whl /tmp/wheels/voxedge-0.0.1a0-py3-none-any.whl
RUN pip3 install --no-cache-dir --index-url ${PIP_INDEX} /tmp/wheels/voxedge-0.0.1a0-py3-none-any.whl \
    && rm -rf /tmp/wheels

# Qwen3 high-performance runtime bundle. This is intentionally separate from
# model/engine artifacts: qwen3-edgellm owns artifact manifest/download/verify,
# while the image owns the runtime worker/plugin binaries and validation scripts.
# These are WORKER BINARIES + plugin .so, NOT models — they ship in BOTH the
# slim and thick variants (base stage).
COPY deploy/jetson-workers/ /opt/jv-workers/
# Runtime only reads the qwen3 artifact manifest under deploy/ (see
# app/core/qwen3_artifact_downloader.py). The rest of the engine repo
# (engine-overlay/, models/, native/, scripts/, tests/, docs/) is build-time
# tooling for jetson-voice-engine — excluded to keep the runtime image slim.
COPY third_party/qwen3-edgellm-jetson/deploy/ /opt/qwen3-edgellm-jetson/deploy/

# Models are downloaded on first start by app/core/model_downloader.py based on
# LANGUAGE_MODE / OVS_PROFILE. Cached in /opt/models volume.
RUN set -eux; \
    mkdir -p /opt/models /opt/edgellm /opt/edgellm-bin /opt/models/qwen3-edgellm; \
    chmod +x /opt/jv-workers/qwen3_asr_worker /opt/jv-workers/qwen3_tts_worker; \
    if [ -f /opt/jv-workers/moss_tts_nano_worker ]; then chmod +x /opt/jv-workers/moss_tts_nano_worker; fi; \
    cp /opt/jv-workers/libNvInfer_edgellm_plugin.so /opt/edgellm/libNvInfer_edgellm_plugin.so; \
    cp /opt/jv-workers/libNvInfer_edgellm_plugin_asr.so /opt/edgellm/libNvInfer_edgellm_plugin_asr.so; \
    cp /opt/jv-workers/libNvInfer_edgellm_plugin.so /opt/edgellm-bin/libNvInfer_edgellm_plugin.so; \
    cp /opt/jv-workers/libNvInfer_edgellm_plugin_asr.so /opt/edgellm-bin/libNvInfer_edgellm_plugin_asr.so

# CustomVoice v0.7.1 fork-port runtime BINARIES (patched inference binary +
# patched plugin). These are runtime executables, not models, so they live in
# base (both variants). The reference talker embeds (a model artifact) are
# baked only in final-thick; the slim variant pulls them at runtime.
# Source: orin-nx ~/customvoice-v071-snapshot/20260526/ (W8A16 PASS, 2026-05-26).
#   qwen3_tts_inference            md5 f50fedc960d8edf7304f897cddbbdaf7
#   libNvInfer_edgellm_plugin.so.1.0 md5 3d6761ebbe0946720f9c1d35a56c1cda
COPY deploy/jetson-workers/customvoice-v071/qwen3_tts_inference            /opt/edgellm-bin/qwen3_tts_inference
COPY deploy/jetson-workers/customvoice-v071/libNvInfer_edgellm_plugin.so.1.0 /opt/edgellm-bin/libNvInfer_edgellm_plugin.so.1.0
RUN set -eux; \
    chmod +x /opt/edgellm-bin/qwen3_tts_inference; \
    chmod +x /opt/edgellm-bin/libNvInfer_edgellm_plugin.so.1.0; \
    echo "CUSTOMVOICE_BIN=/opt/edgellm-bin/qwen3_tts_inference"                   >> /etc/openvoicestream.env; \
    echo "CUSTOMVOICE_PLUGIN=/opt/edgellm-bin/libNvInfer_edgellm_plugin.so.1.0"   >> /etc/openvoicestream.env; \
    echo "CUSTOMVOICE_TALKER_EMBEDS=/opt/edgellm-bin/ref_talker_embeds_15row.bin" >> /etc/openvoicestream.env

ENV MODEL_DIR=/opt/models \
    NVIDIA_VISIBLE_DEVICES=all \
    CUDA_MODULE_LOADING=LAZY \
    EDGE_LLM_BASE=/opt/edgellm-bin \
    EDGE_LLM_BUILD_DIR=. \
    OVS_WORKER_BUILD=/opt/jv-workers \
    QWEN3_EDGELLM_JETSON_ROOT=/opt/qwen3-edgellm-jetson \
    EDGELLM_PLUGIN_PATH=/opt/edgellm-bin/libNvInfer_edgellm_plugin.so \
    LD_LIBRARY_PATH=/usr/local/lib/python3.10/dist-packages/onnxruntime/capi:/host-cuda:/host-nvidia-libs:/host-libs \
    PYTHONPATH=/opt/speech:/usr/lib/python3.10/dist-packages

LABEL org.opencontainers.image.title="OpenVoiceStream" \
      org.opencontainers.image.source="https://github.com/suharvest/openvoicestream" \
      org.opencontainers.image.description="GPU-accelerated speech service for Jetson Orin"

WORKDIR /opt/speech
EXPOSE 8000

ENTRYPOINT ["/opt/speech/entrypoint.jetson.sh"]
CMD ["python3", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]

# ===========================================================================
# Stage: final-thick — base + baked model/engine artifacts (factory/offline)
# ===========================================================================
FROM base AS final-thick

# CustomVoice reference talker embeds (model artifact). Baked here so the
# offline image needs no first-start download. CustomVoice profiles opt-in via
# QWEN3_TTS_PRELOAD_TALKER_EMBEDS / CUSTOMVOICE_TALKER_EMBEDS (env already
# written in base, pointing at this path).
#   ref_talker_embeds_15row.bin    md5 fed8b23ca46246f5993ec26ab7d5c0f4
COPY deploy/jetson-workers/customvoice-v071/ref_talker_embeds_15row.bin /opt/edgellm-bin/ref_talker_embeds_15row.bin

# Qwen3 / Matcha / Kokoro / MOSS engines may additionally be baked into a thick
# image by COPYing prebuilt artifacts into /opt/models here. By default they are
# left out (engine_resolver / *_artifacts.py rebuild or fetch on first start),
# so the thick variant differs from slim only by the CustomVoice embeds above
# plus whatever the operator stages. Keep this stage's model COPYs additive.

# ===========================================================================
# Stage: final-slim — base only; models/engines pulled at first start from HF/CDN
# ===========================================================================
# No model/engine artifacts. On first start, app/core/model_downloader.py
# (ensure_models) fetches everything the active profile needs:
#   - Qwen3 ASR/TTS engines     → _ensure_qwen3_artifacts (qwen3-edgellm script + manifest)
#   - MOSS TTS engines+codec     → _ensure_moss_artifacts  (deploy/artifacts/moss_manifest.json)
#   - Matcha / Paraformer (CDN)  → MODELS[...] tarballs (sensecraft-statics CDN)
#   - Kokoro (CDN)               → MODELS["en"] tarball
#   - CustomVoice talker embeds  → pulled at runtime when the CustomVoice profile
#                                  is selected (HF), since they are not baked here.
# This is the DEFAULT build target (last stage).
FROM base AS final-slim
