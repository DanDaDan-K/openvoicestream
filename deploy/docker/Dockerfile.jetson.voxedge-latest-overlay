# Overlay: bake the branch voxedge (refactor/turn-driver-unification —
# conversation-split + unified server/client turn_driver) onto a server/-layout
# base image, keeping the /v2v multi-turn fix. voxedge is pure-Python
# (numpy-only), so this is a thin pip-replace layer — no engine rebuild.
#
# WHY: production server-loop bakes an OLDER voxedge (2026-06-11). The
# turn_driver unification is byte-equivalent for server-loop, so this is a
# maintainability/freshness update, not a behavior change — validate on dev
# (server-loop e2e suite) before prod.
#
# The wheel at deploy/wheels/voxedge-0.0.1a0-py3-none-any.whl is gitignored;
# rebuild it with scripts/build_voxedge_wheel.sh (provenance in
# deploy/wheels/voxedge.BUILD.txt) and stage it into the build context first.
#
# Build (context = repo root, on the arm64 device; --sudo docker):
#   docker build -f deploy/docker/Dockerfile.jetson.voxedge-latest-overlay \
#     --build-arg BASE=<base image> -t <base>-voxedge0a51538 .
#   dev validate:  BASE=...:prod-unified-v8
#   prod deploy:   BASE=...:v0.8.0-edgellm-20260611-prefix
ARG BASE
FROM ${BASE}
ARG BASE

# Replace the baked voxedge with the branch wheel (pure-python; --no-deps keeps
# the image's numpy/runtime untouched).
COPY deploy/wheels/voxedge-0.0.1a0-py3-none-any.whl /tmp/voxedge.whl
RUN python3 -m pip install --no-deps --force-reinstall /tmp/voxedge.whl \
    && rm -f /tmp/voxedge.whl \
    && python3 -c "import voxedge, voxedge.engine.turn_driver as t; print('voxedge ok:', t.__file__)"

# Keep the /v2v no-VAD multi-turn fix (idempotent; no-op if base already fixed).
COPY deploy/docker/_patch_v2v_multiturn.py /tmp/_patch_v2v_multiturn.py
RUN python3 /tmp/_patch_v2v_multiturn.py && rm -f /tmp/_patch_v2v_multiturn.py

LABEL build.overlay="voxedge-turndriver+v2v-multiturn"
LABEL build.voxedge_sha="0a51538"
LABEL build.base="${BASE}"
