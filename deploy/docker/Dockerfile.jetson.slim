# syntax=docker/dockerfile:1.6
#
# OpenVoiceStream — Jetson Orin slim variant
#
# Same runtime as Dockerfile.jetson, with extra size cuts:
#   1. pip install --no-compile + purge tests/ + __pycache__ + .pyc  → ~50-80MB
#   2. Hardlink/symlink-dedupe libNvInfer_edgellm_plugin*.so across /opt/edgellm,
#      /opt/edgellm-bin, /opt/jv-workers (3 copies of ~140MB → 1 set).
#      cp creates new bytes in a new layer ≈ 280MB wasted; use ln -sf instead.
#   3. Drop apt build-deps (binutils) post-install where safe.
#
# ── Multi-target (BAKE_MODELS) ──────────────────────────────────────────────
# Mirrors Dockerfile.jetson: THREE stages.
#   base         — code + runtime libs + worker binaries + .so (size-optimized).
#   final-thick  — FROM base + COPY baked CustomVoice ref talker embeds (offline).
#   final-slim   — FROM base only; models/engines pulled at first start.
#
# Build THICK (factory / offline):
#   docker build -f deploy/docker/Dockerfile.jetson.slim --target final-thick \
#                --build-arg LANGUAGE_MODE=multilanguage \
#                -t openvoicestream:jetson-slim-thick .
#
# Build SLIM (runtime-pull, smallest):
#   docker build -f deploy/docker/Dockerfile.jetson.slim --target final-slim \
#                --build-arg LANGUAGE_MODE=multilanguage \
#                -t openvoicestream:jetson-slim .
#
# Default `docker build` (no --target) builds the LAST stage (final-slim).

ARG LANGUAGE_MODE=zh_en

# ===========================================================================
# Stage: base — size-optimized code + runtime libs + worker binaries + .so
# ===========================================================================
FROM arm64v8/ubuntu:22.04 AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_INDEX_URL=${PIP_INDEX}
ENV PYTHONDONTWRITEBYTECODE=1

# System deps + Python 3.10. binutils kept (needed by some onnxruntime ops).
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.10 python3.10-dev python3-pip \
        libasound2 libsndfile1 sox curl ca-certificates binutils bzip2 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1 \
    && rm -rf /var/lib/apt/lists/*

# FastAPI + runtime deps. --no-compile skips .pyc gen; we also purge tests/
# and __pycache__ at the end of the same RUN so deletions actually shrink
# the layer (later RUN deletes only add whiteouts).
RUN pip3 install --no-cache-dir --no-compile --index-url ${PIP_INDEX} \
        fastapi \
        "uvicorn[standard]" \
        soundfile \
        python-multipart \
        numpy \
        tokenizers \
        "webrtcvad-wheels>=2.0.14" \
        "cuda-python>=12,<13" \
        websockets \
        requests \
        "pysbd>=0.3.4" \
        "onnxruntime>=1.20" \
        piper-phonemize \
        prometheus_client \
        httpx \
        kaldi-native-fbank \
        sentencepiece \
 && SP=$(python3 -c "import sysconfig;print(sysconfig.get_paths()['purelib'])") \
 && find "$SP" -maxdepth 3 -type d \( -name tests -o -name test \) -exec rm -rf {} + 2>/dev/null || true \
 && find "$SP" -depth -type d -name __pycache__ -exec rm -rf {} + \
 && find "$SP" -type f -name '*.pyc' -delete

ARG LANGUAGE_MODE=zh_en
ENV LANGUAGE_MODE=${LANGUAGE_MODE}

RUN set -eux; \
    case "$LANGUAGE_MODE" in \
      zh_en) echo "OVS_PROFILE_DEFAULT=jetson-zh-en" >> /etc/openvoicestream.env ;; \
      multilanguage) echo "OVS_PROFILE_DEFAULT=jetson-qwen3asr-matcha-nx" >> /etc/openvoicestream.env ;; \
      *) echo "Unknown LANGUAGE_MODE=$LANGUAGE_MODE (expected zh_en|multilanguage)" >&2; exit 1 ;; \
    esac; \
    rm -rf /root/.cache /tmp/*

# Application code
COPY server/      /opt/speech/server/
COPY configs/  /opt/speech/configs/
COPY voices/   /opt/speech/voices/
COPY deploy/artifacts/ /opt/speech/deploy/artifacts/
COPY deploy/docker/entrypoint.jetson.sh /opt/speech/entrypoint.jetson.sh
RUN chmod +x /opt/speech/entrypoint.jetson.sh

# ── voxedge (edge-native voice library) ───────────────────────────────
# Post-migration app/ imports voxedge.*; install the pure-Python py3-none-any
# wheel (numpy-only core) WITHOUT extras (heavy backend deps already in image,
# voxedge imports lazy). Wheel staged into deploy/wheels/ on the build host.
# See docs/specs/cutover-dockerfile-draft.md §2.
COPY deploy/wheels/voxedge-0.0.2a0-py3-none-any.whl /tmp/wheels/voxedge-0.0.2a0-py3-none-any.whl
RUN pip3 install --no-cache-dir --no-compile --index-url ${PIP_INDEX} /tmp/wheels/voxedge-0.0.2a0-py3-none-any.whl \
    && rm -rf /tmp/wheels

# Qwen3 high-performance runtime bundle (WORKER BINARIES + plugin .so, NOT
# models — shipped in both variants).
# Explicit file list (NOT the whole dir) so customvoice-v071/ is NOT duplicated
# here — those binaries go to /opt/edgellm-bin below. --chmod=0755 sets the exec
# bit at copy time so we don't need a `chmod +x` RUN (which would re-copy each
# ~60MB binary into a second layer; ~170MB of waste).
COPY --chmod=0755 \
    deploy/jetson-workers/qwen3_asr_worker \
    deploy/jetson-workers/qwen3_tts_worker \
    deploy/jetson-workers/spark_tts_worker \
    deploy/jetson-workers/moss_tts_nano_worker \
    deploy/jetson-workers/moss_tts_nano_ort_worker.py \
    deploy/jetson-workers/libNvInfer_edgellm_plugin.so \
    deploy/jetson-workers/libNvInfer_edgellm_plugin_asr.so \
    deploy/jetson-workers/MANIFEST.json \
    /opt/jv-workers/
# Runtime only reads the qwen3 artifact manifest under deploy/ (see
# server/core/qwen3_artifact_downloader.py). The rest of the engine repo
# (engine-overlay/, models/, native/, scripts/, tests/, docs/) is build-time
# tooling for jetson-voice-engine — excluded to keep the runtime image slim.
COPY third_party/jetson-voice-engine/deploy/ /opt/qwen3-edgellm-jetson/deploy/

# Replace 4x cp (~280MB duplicated bytes in this layer) with symlinks
# pointing back to /opt/jv-workers. dlopen / LD_LIBRARY_PATH transparently
# follows symlinks; runtime semantics unchanged.
RUN set -eux; \
    mkdir -p /opt/models /opt/edgellm /opt/edgellm-bin /opt/models/qwen3-edgellm; \
    ln -sf /opt/jv-workers/libNvInfer_edgellm_plugin.so     /opt/edgellm/libNvInfer_edgellm_plugin.so; \
    ln -sf /opt/jv-workers/libNvInfer_edgellm_plugin_asr.so /opt/edgellm/libNvInfer_edgellm_plugin_asr.so; \
    ln -sf /opt/jv-workers/libNvInfer_edgellm_plugin.so     /opt/edgellm-bin/libNvInfer_edgellm_plugin.so; \
    ln -sf /opt/jv-workers/libNvInfer_edgellm_plugin_asr.so /opt/edgellm-bin/libNvInfer_edgellm_plugin_asr.so

# CustomVoice v0.7.1 fork-port runtime BINARIES (patched inference binary +
# patched plugin). Runtime executables, not models → base (both variants).
# The reference talker embeds (model artifact) are baked only in final-thick.
COPY --chmod=0755 deploy/jetson-workers/customvoice-v071/qwen3_tts_inference            /opt/edgellm-bin/qwen3_tts_inference
COPY --chmod=0755 deploy/jetson-workers/customvoice-v071/libNvInfer_edgellm_plugin.so.1.0 /opt/edgellm-bin/libNvInfer_edgellm_plugin.so.1.0
RUN set -eux; \
    echo "CUSTOMVOICE_BIN=/opt/edgellm-bin/qwen3_tts_inference"                   >> /etc/openvoicestream.env; \
    echo "CUSTOMVOICE_PLUGIN=/opt/edgellm-bin/libNvInfer_edgellm_plugin.so.1.0"   >> /etc/openvoicestream.env; \
    echo "CUSTOMVOICE_TALKER_EMBEDS=/opt/edgellm-bin/ref_talker_embeds_15row.bin" >> /etc/openvoicestream.env

ENV MODEL_DIR=/opt/models \
    NVIDIA_VISIBLE_DEVICES=all \
    CUDA_MODULE_LOADING=LAZY \
    EDGE_LLM_BASE=/opt/edgellm-bin \
    EDGE_LLM_BUILD_DIR=. \
    OVS_WORKER_BUILD=/opt/jv-workers \
    QWEN3_EDGELLM_JETSON_ROOT=/opt/qwen3-edgellm-jetson \
    EDGELLM_PLUGIN_PATH=/opt/edgellm-bin/libNvInfer_edgellm_plugin.so \
    LD_LIBRARY_PATH=/usr/local/lib/python3.10/dist-packages/onnxruntime/capi:/host-cuda:/host-nvidia-libs:/host-libs \
    PYTHONPATH=/opt/speech:/usr/lib/python3.10/dist-packages

LABEL org.opencontainers.image.title="OpenVoiceStream" \
      org.opencontainers.image.source="https://github.com/suharvest/openvoicestream" \
      org.opencontainers.image.description="GPU-accelerated speech service for Jetson Orin (slim)"

WORKDIR /opt/speech
EXPOSE 8000

ENTRYPOINT ["/opt/speech/entrypoint.jetson.sh"]
CMD ["python3", "-m", "uvicorn", "server.main:app", "--host", "0.0.0.0", "--port", "8000"]

# ===========================================================================
# Stage: final-thick — base + baked CustomVoice ref talker embeds (offline)
# ===========================================================================
FROM base AS final-thick

# CustomVoice reference talker embeds (model artifact). Baked here for offline.
#   ref_talker_embeds_15row.bin    md5 fed8b23ca46246f5993ec26ab7d5c0f4
COPY deploy/jetson-workers/customvoice-v071/ref_talker_embeds_15row.bin /opt/edgellm-bin/ref_talker_embeds_15row.bin

# ===========================================================================
# Stage: final-slim — base only; models/engines pulled at first start (DEFAULT)
# ===========================================================================
FROM base AS final-slim
