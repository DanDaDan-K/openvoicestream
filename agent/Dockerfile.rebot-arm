# OpenVoiceStream Agent — reBot B601-DM voice-arm image (apps/voice_rebot_arm).
#
# Independent from the SO-ARM image: this one bundles the reBot B601-DM SDK
# (reBotArm_control_py + motorbridge) instead of the LeRobot/Feetech stack.
#
# Build context = repo root (so `COPY agent` resolves):
#   docker build -f agent/Dockerfile.rebot-arm -t ovs-agent-rebot:latest .
#
# RUNTIME (do NOT bake into the image):
#   * Mount the B601-DM serial device:  --device /dev/ttyACM1
#     (the SDK reads channel.startswith("/dev/tty") to choose serial vs CAN,
#      so the channel MUST be the REALPATH /dev/ttyACM1, not a by-id symlink).
#   * Run as ROOT (--user 0 or default) so the container bypasses the host
#     dialout-group permission requirement on /dev/ttyACM1.
#   * Set REBOT_CHANNEL=/dev/ttyACM1 (default) and, if needed, REBOT_REPO_ROOT.
#
# NOTE: this Dockerfile is provided for completeness; per task scope it is
# NOT built here. Image bring-up + device wiring is a later (powered) phase.

# Use an aarch64 base for the Jetson/edge target. python:3.10-slim is
# multi-arch so it resolves to arm64 on the device. Python is pinned to 3.10
# (NOT 3.11) because the Pinocchio `pin==4.0.0` aarch64 wheel was verified to
# install cleanly on cpython 3.10 on this Jetson; 3.11 wheels are not assured.
# Phase A is CPU-only (wakeword + audio + actuator + SLV/LLM clients); the
# heavy ASR/LLM/TTS run in the shared seeed-voice/edge-llm GPU containers, so
# no CUDA base is needed here.
FROM python:3.10-slim

ARG APT_MIRROR=mirrors.tuna.tsinghua.edu.cn
ARG PIP_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_INDEX_URL=${PIP_INDEX} \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

RUN if [ -n "$APT_MIRROR" ]; then \
        sed -i "s|deb.debian.org|$APT_MIRROR|g; s|security.debian.org|$APT_MIRROR|g" \
            /etc/apt/sources.list /etc/apt/sources.list.d/debian.sources 2>/dev/null || true; \
    fi && \
    apt-get update && apt-get install -y --no-install-recommends \
        libportaudio2 \
        libsndfile1 \
        ca-certificates \
        git \
        build-essential \
        portaudio19-dev \
        libgl1 \
        libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*
# build-essential + portaudio19-dev: pyaudio has no aarch64 wheel and is
# compiled from source on python:3.10-slim (needs gcc + portaudio headers).
# libgl1 + libglib2.0-0: Phase B vision needs cv2 at runtime. pyorbbecsdk2
# pulls full opencv-python (libGL.so.1 / libgthread), which the slim base
# lacks — without these, `import cv2` fails with "libGL.so.1: cannot open".

WORKDIR /opt/slv

# ── reBot B601-DM SDK ─────────────────────────────────────────────────
# Clone reBotArm_control_py (vectorBH6) into /opt/rebot and install editable.
# find_rebot_repo_root() resolves this canonical /opt/rebot location (or
# $REBOT_REPO_ROOT). The SDK's bundled config/arm.yaml ships the full B601-DM
# 6-joint + gripper motor map; our actuator copies it and overrides only the
# `channel` field at connect time. Pinned to the verified commit.
ARG REBOT_SDK_REF=893f09568db51d4da46b2c368f995d3421161bd6
# SDK patches (no push access to vectorBH6, so device-verified fixes ride
# along as patches applied after the pinned checkout):
#   0001: enable() auto-clears latched Damiao faults in-band (status 12 = coil
#         over-temp — the chronic joint-4 boot lockout; clear_error() verified
#         live on-device 2026-07-14/15, no power cycle needed; capped per motor
#         so a genuinely faulting motor still fails loudly).
#   0002: move_to_traj CLIK fallback — the single-shot IK solve is
#         seed-sensitive and rejects reachable poses; plan straight to the
#         target and accept only if tracking provably arrived (all waypoints
#         solved, endpoint ≤10mm, no elbow-flip joint jumps). Kills the
#         chronic sporadic "pregrasp IK failed".
COPY agent/rebot-sdk-patches /tmp/rebot-sdk-patches
RUN git clone https://github.com/vectorBH6/reBotArm_control_py.git \
        /opt/rebot/reBotArm_control_py \
    && git -C /opt/rebot/reBotArm_control_py checkout ${REBOT_SDK_REF} \
    && git -C /opt/rebot/reBotArm_control_py apply --stat --apply \
        /tmp/rebot-sdk-patches/*.patch \
    && pip install --no-cache-dir -e /opt/rebot/reBotArm_control_py

# Python deps:
#   * pin>=3.9.0  — Pinocchio kinematics (IK/FK) used by the SDK.
#   * pin==4.0.0 — Pinocchio kinematics (IK/FK); aarch64 wheel verified on the
#     Jetson under cpython 3.10 (pulls eigenpy/coal/cmeel-* prebuilt wheels).
#   * motorbridge — CAN motor bridge (B601-DM low-level transport). Confirmed
#     on PyPI (it is a declared dep of reBotArm_control_py, resolved by pip);
#     installed explicitly here to be safe.
#   * onnxruntime (CPU) — openWakeWord wakeword inference. Phase A uses the CPU
#     EP (same as the production SO-ARM slim image); the wakeword models are
#     small. The aarch64 onnxruntime-gpu / TensorRT-EP wheel (NVIDIA jp index)
#     is only needed for Phase B's YOLO segmenter — wire it then.
RUN pip install --no-cache-dir \
        "websockets>=12" \
        "sounddevice>=0.4" \
        "numpy>=1.24" \
        "openai>=1.40" \
        "pyyaml>=6.0" \
        "pysbd>=0.3.4" \
        "fastapi>=0.110" \
        "uvicorn[standard]>=0.27" \
        "openwakeword>=0.6" \
        "pyaudio>=0.2.13" \
        "onnxruntime>=1.17,<2" \
        "opencv-python-headless>=4.8,<5" \
        "scipy>=1.10" \
        "pin>=3.9.0" \
        "motorbridge==0.2.8" \
        "pyorbbecsdk2"
# opencv is capped below 5 because it genuinely drifted: unbounded, the same
# Dockerfile produced 4.13.0 on 2026-07-15 (ddandadan/voice-rebot-arm:v1.1.0)
# and 5.0.0 six days later, once upstream published the major bump. perception/
# leans on cv2 for letterboxing, resizing and mask post-processing, so that is
# not a change to make by accident. A build that succeeds is not the same thing
# as a build that reproduces the validated image.
#
# The onnxruntime bound is cheap insurance rather than a fix for anything
# observed. Its 1.24.0-vs-1.23.2 gap between those two builds is not drift at
# all: PIP_INDEX defaults to a mirror that carries neither 1.24 nor anything
# newer, while v1.1.0 was built with PIP_INDEX=https://pypi.org/simple. Same
# Dockerfile, different index, different wheel -- worth knowing when a build
# elsewhere disagrees with this one.
#
# pyorbbecsdk2: Orbbec Gemini2 camera SDK for Phase B vision grasp (import
# name `pyorbbecsdk`, cp310/aarch64 wheel). Real-machine verified: box
# detection + camera-frame grasp pose on the placed cardboard box (CPU EP).
# It pulls full opencv-python (hence libgl1 above). The YOLOE-seg box model
# is NOT baked — it is mounted at runtime (data artifact, kept swappable).
# motorbridge PINNED to 0.2.8 — the version powered-validated on the device's
# /home/seeed/venv (move_to / gripper / enable all confirmed on hardware).
# Leaving it unpinned (>=0.2.8) is non-deterministic: builds have resolved to
# 0.2.2 and 0.4.2 on different runs depending on what the mirror served.

# Bake the openWakeWord models (incl. hey_jarvis_v0.1 + the melspectrogram /
# embedding feature models) into the image. Our wake source loads
# openwakeword.Model([...]) which expects them under the package's
# resources/models dir; without this they are absent and wake is disabled at
# runtime (this image has no entrypoint download step). download_models()
# fetches them at build (verified reachable from the device).
RUN python -c "import openwakeword.utils; openwakeword.utils.download_models()"

# Agent source (self-contained; no SLV server tree needed). Copied LAST so a
# code edit only re-runs this cheap install layer — the SDK clone, the big
# wheel install and the model download above all stay cached. Dependencies are
# already satisfied by the wheel layer, so `pip install` here just registers
# the package (kept dependency-bearing so a fresh build is still complete).
COPY agent /opt/slv/agent
RUN pip install --no-cache-dir /opt/slv/agent
# voxedge from PyPI. This used to COPY a committed wheel because the published
# 0.0.1a0 was stale (no ``engine.turn_driver``, which ovs_agent/tools/runner.py
# imports, so the container crash-looped). That wheel was never actually
# committed -- deploy/wheels/ holds only a provenance note, and for 0.0.2a0 at
# that -- so this COPY referenced a file that does not exist and the build has
# been unbuildable from a fresh clone ever since. The published image was made
# on a machine that happened to have the wheel lying around.
#
# 0.0.5a0 is on PyPI and carries the v0.9.0 work (WAV-ingest ASR,
# streaming-only TTS routing), so the wheel dance is no longer needed.
#
# pypi.org is named explicitly: PIP_INDEX defaults to a mirror, and mirrors lag
# hours to days behind a fresh release -- exactly how the stale-0.0.1a0 problem
# started. The mirror stays as an extra index so a China build keeps a fallback.
ARG VOXEDGE_VERSION=0.0.5a0
RUN pip install --no-cache-dir --force-reinstall --no-deps \
        --index-url https://pypi.org/simple \
        --extra-index-url ${PIP_INDEX} \
        "voxedge==${VOXEDGE_VERSION}"
ENV PYTHONPATH=/opt/slv/agent

RUN apt-get update && apt-get install -y --no-install-recommends pulseaudio-utils \
    && rm -rf /var/lib/apt/lists/*

ENV REBOT_REPO_ROOT=/opt/rebot \
    REBOT_CHANNEL=auto \
    OBSERVATION_PORT=8775 \
    MIC_INDEX=reSpeaker \
    MIC_CHANNELS=6 \
    SPEAKER_DEVICE=reSpeaker \
    WAKEWORD_MODEL="hey jarvis" \
    OVS_AGENT_SERVER_LOOP=1 \
    CONFIG_DIR=/opt/slv/agent/ovs_agent/apps/voice_rebot_arm
# OVS_AGENT_SERVER_LOOP=1: match production — SLV (seeed-voice, already in
# voxedge + server-loop mode) runs the LLM + tool loop; the agent advertises
# its arm tools and executes remote tool_calls. Without this the agent falls
# back to the legacy client-loop ("skipping tool advertise"), the unvalidated
# path for the arm.
# MIC_INDEX=reSpeaker: config's audio_input_device is ${MIC_INDEX:-}; empty
# errors "Multiple input devices found for ''" (reSpeaker + Jetson APE both
# enumerate). voice_rebot_arm/app.py calls resolve_input_index() which
# handles 'auto' (resolves to reSpeaker) and name substrings. A name like
# 'reSpeaker' is more robust than a numeric index (no enumeration-order drift).

COPY agent/entrypoint-rebot.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Observation HTTP server port (distinct from voice_arm's 8765).
EXPOSE 8775

ENTRYPOINT ["/entrypoint.sh"]
